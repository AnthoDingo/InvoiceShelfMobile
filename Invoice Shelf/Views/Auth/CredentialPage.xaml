<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InvoiceShelf.Views.Auth.CredentialPage"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Auth"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             x:DataType="viewmodels:CredentialViewModel"
             Title="Connexion">

    <Shell.TitleView>
        <Grid>
            <ImageButton
                HorizontalOptions="End"
                VerticalOptions="Center"
                Command="{Binding BackToEndpointCommand}"
                BackgroundColor="Transparent"
                ToolTipProperties.Text="Changer de serveur"
                MaximumHeightRequest="30" MaximumWidthRequest="30"/>
        </Grid>
    </Shell.TitleView>

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Margin="24,40,24,0" Spacing="0" Style="{StaticResource ResponsiveContainer}">

            <Image Source="logo.png" HorizontalOptions="Center" HeightRequest="180" Margin="0,0,0,36"/>

            <!-- Erreur globale -->
            <Border
                IsVisible="{Binding ErrorMessageVisible}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#FEE2E2"
                Padding="14,12"
                Margin="0,0,0,16">
                <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" LineBreakMode="WordWrap"/>
            </Border>

            <!-- Email -->
            <Label Text="Adresse email" FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   Margin="0,0,0,6"/>
            <Border
                Stroke="{Binding UsernameBorderColor}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray900}}"
                Padding="14,0">
                <Entry
                    FontSize="15"
                    Text="{Binding Username}"
                    Placeholder="votre@email.com"
                    PlaceholderColor="{StaticResource Gray400}"
                    Keyboard="Email"
                    ReturnType="Next"/>
            </Border>
            <Label
                Text="Ce champ est requis"
                FontSize="12"
                TextColor="{StaticResource StatusOverdue}"
                Margin="4,4,0,0"
                IsVisible="{Binding UsernameErrorVisible}"/>

            <!-- Mot de passe -->
            <Label Text="Mot de passe" FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   Margin="0,20,0,6"/>
            <Border
                Stroke="{Binding PasswordBorderColor}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray900}}"
                Padding="14,0">
                <Entry
                    FontSize="15"
                    IsPassword="True"
                    Text="{Binding Password}"
                    Placeholder="••••••••"
                    PlaceholderColor="{StaticResource Gray400}"
                    ReturnType="Go"
                    ReturnCommand="{Binding LoginCommand}"/>
            </Border>
            <Label
                Text="Ce champ est requis"
                FontSize="12"
                TextColor="{StaticResource StatusOverdue}"
                Margin="4,4,0,0"
                IsVisible="{Binding PasswordErrorVisible}"/>

            <!-- Mot de passe oublié -->
            <Label
                Text="Mot de passe oublié ?"
                Margin="0,14,0,0"
                FontSize="13"
                TextColor="{StaticResource Primary}"
                TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- Bouton Se connecter -->
            <Border
                StrokeThickness="0"
                BackgroundColor="{StaticResource Primary}"
                Margin="0,36,0,0"
                Padding="0"
                StrokeShape="RoundRectangle 10"
                MinimumHeightRequest="52">
                <Grid Padding="16">
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="White" WidthRequest="22" HeightRequest="22"
                        HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label
                        Text="Se connecter"
                        TextColor="White" FontSize="16" FontAttributes="Bold"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LoginCommand}"/>
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
