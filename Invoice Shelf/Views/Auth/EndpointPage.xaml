<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InvoiceShelf.Views.Auth.EndpointPage"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Auth"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             xmlns:loc="clr-namespace:InvoiceShelf.Localization"
             x:DataType="viewmodels:EndpointViewModel"
             Title="EndpointPage">
    <Shell.TitleView>
        <ContentView />
    </Shell.TitleView>

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Margin="25,40,25,0" Spacing="0" Style="{StaticResource ResponsiveContainer}">

            <Image
                Source="logo.png"
                HorizontalOptions="Center"
                HeightRequest="180"
                Margin="0,0,0,40"/>

            <Label
                Text="{loc:Translate Endpoint_ServerUrlLabel}"
                FontSize="13"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                Margin="0,0,0,6"/>

            <Border
                Stroke="{Binding EntryBorderColor}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray900}}"
                Padding="14,0">
                <Entry
                    FontSize="15"
                    Text="{Binding BaseUrl}"
                    Placeholder="https://invoiceshelf.example.com"
                    PlaceholderColor="{StaticResource Gray400}"
                    ReturnType="Go"
                    ReturnCommand="{Binding CheckServerCommand}"/>
            </Border>

            <Label
                Text="{loc:Translate Endpoint_UrlRequired}"
                FontSize="12"
                TextColor="{StaticResource StatusOverdue}"
                Margin="4,4,0,0"
                IsVisible="{Binding ErrorIsVisible}"/>

            <Label
                Margin="0,16,0,0"
                Text="{loc:Translate Endpoint_HelperText}"
                FontSize="13"
                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                LineBreakMode="WordWrap"/>

            <Border
                StrokeThickness="0"
                BackgroundColor="{StaticResource Primary}"
                Margin="0,40,0,0"
                Padding="0"
                StrokeShape="RoundRectangle 10"
                MinimumHeightRequest="50">

                <Grid Padding="16">
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="White"
                        WidthRequest="22"
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                    <Label
                        Text="{loc:Translate Endpoint_Continue}"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CheckServerCommand}"/>
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
