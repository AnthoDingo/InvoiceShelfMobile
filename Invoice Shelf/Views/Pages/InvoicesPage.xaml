<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tabview="clr-namespace:MPowerKit.TabView;assembly=MPowerKit.TabView"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Pages"
             xmlns:controls="clr-namespace:InvoiceShelf.Controls"
             x:Class="InvoiceShelf.Views.Pages.InvoicesPage"
             x:DataType="viewmodels:InvoicesViewModel"
             Title="Factures">

    <Grid Style="{StaticResource ResponsiveContainer}">
        <tabview:TabView
            BackgroundColor="Transparent"
            SelectedHeaderBackgroundColor="Transparent">

            <tabview:TabView.HeaderItemsLayout>
                <Grid
                    ColumnDefinitions="*,*,*"
                    BackgroundColor="Transparent"
                    WidthRequest="{Binding Width, Source={RelativeSource Mode=FindAncestor, AncestorType={x:Type ScrollView}}}"/>
            </tabview:TabView.HeaderItemsLayout>

            <tabview:TabView.HeaderTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid RowDefinitions="*,Auto">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding .}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                            VerticalOptions="Center"
                            Margin="0,12"/>
                        <Border
                            Grid.Row="1"
                            HeightRequest="2"
                            HorizontalOptions="Fill"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                    </Grid>
                </DataTemplate>
            </tabview:TabView.HeaderTemplate>

            <tabview:TabView.SelectedHeaderTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid RowDefinitions="*,Auto" BackgroundColor="Transparent">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding .}"
                            TextColor="{StaticResource Primary}"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            Margin="0,12"/>
                        <Border
                            Grid.Row="1"
                            HeightRequest="2.5"
                            HorizontalOptions="Fill"
                            BackgroundColor="{StaticResource Primary}"/>
                    </Grid>
                </DataTemplate>
            </tabview:TabView.SelectedHeaderTemplate>

            <!-- Brouillons -->
            <tabview:TabViewItem Header="Brouillons" Column="0">
                <Grid x:DataType="viewmodels:InvoicesViewModel">
                    <controls:InvoiceListView
                        ItemsSource="{Binding Drafts}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenInvoiceCommand}"
                        EmptyMessage="Aucun brouillon"
                        EmptySubMessage="Vos factures brouillons apparaîtront ici."/>
                </Grid>
            </tabview:TabViewItem>

            <!-- Envoyées -->
            <tabview:TabViewItem Header="Envoyées" Column="1">
                <Grid x:DataType="viewmodels:InvoicesViewModel">
                    <controls:InvoiceListView
                        ItemsSource="{Binding Sents}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenInvoiceCommand}"
                        EmptyMessage="Aucune facture envoyée"
                        EmptySubMessage="Vos factures envoyées apparaîtront ici."/>
                </Grid>
            </tabview:TabViewItem>

            <!-- Toutes -->
            <tabview:TabViewItem Header="Toutes" Column="2">
                <Grid x:DataType="viewmodels:InvoicesViewModel">
                    <controls:InvoiceListView
                        ItemsSource="{Binding Invoices}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenInvoiceCommand}"
                        EmptyMessage="Aucune facture"
                        EmptySubMessage="Vos factures apparaîtront ici."/>
                </Grid>
            </tabview:TabViewItem>

        </tabview:TabView>

        <!-- Bouton flottant : nouvelle facture -->
        <Button
            Text="+"
            FontSize="26"
            FontAttributes="Bold"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            Padding="0"
            BackgroundColor="{StaticResource Primary}"
            TextColor="White"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,20,20"
            Command="{Binding NewInvoiceCommand}"/>
    </Grid>
</ContentPage>
