<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:InvoiceShelf.Localization"
             x:Class="InvoiceShelf.Views.Pages.SplashPage"
             BackgroundColor="{StaticResource Primary}"
             Title="SplashPage"
             Shell.NavBarIsVisible="False">

    <Shell.TitleView>
        <ContentView/>
    </Shell.TitleView>

    <Grid>

        <Image
            Source="splash_wave_bg.png"
            Aspect="AspectFill"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"/>

        <VerticalStackLayout Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">

            <Image
                Margin="20,0,20,0"
                Source="logo.png"
                Aspect="AspectFit"
                HeightRequest="90"
                HorizontalOptions="Center"/>

            <ActivityIndicator
                IsRunning="True"
                Color="White"
                WidthRequest="28"
                HeightRequest="28"
                HorizontalOptions="Center"/>

            <Label
                Text="{loc:Translate Common_Loading}"
                TextColor="White"
                Opacity="0.7"
                FontSize="13"
                HorizontalOptions="Center"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
