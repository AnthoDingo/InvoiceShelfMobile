<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Pages"
             xmlns:models="clr-namespace:InvoiceShelf.Models.Admin"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             x:Class="InvoiceShelf.Views.Pages.ExpensesPage"
             x:DataType="viewmodels:ExpensesViewModel"
             Title="Dépenses">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:ShortDateConverter  x:Key="ShortDateConverter"/>
            <helpers:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            <helpers:IsNotNullConverter  x:Key="IsNotNullConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

    <RefreshView
        IsRefreshing="{Binding IsRefreshing}"
        Command="{Binding RefreshCommand}">

        <Grid>

            <!-- Expenses list -->
            <CollectionView
                ItemsSource="{Binding Expenses}"
                IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Expense">
                        <Grid Padding="16,14" Margin="0,-8,0,0" ColumnDefinitions="Auto,*,Auto">

                            <!-- Category badge -->
                            <Border
                                Grid.Column="0"
                                WidthRequest="44"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource Secondary}"
                                VerticalOptions="Center">
                                <Label
                                    Text="💸"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                            <!-- Category + notes -->
                            <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" Spacing="3" VerticalOptions="Center">
                                <Label
                                    Text="{Binding CategoryName}"
                                    FontSize="15"
                                    FontAttributes="Bold"/>
                                <Label
                                    Text="{Binding Notes}"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                    LineBreakMode="TailTruncation"
                                    IsVisible="{Binding Notes, Converter={StaticResource IsNotNullConverter}}"/>
                                <Label
                                    Text="{Binding Customer.Name}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                    IsVisible="{Binding Customer, Converter={StaticResource IsNotNullConverter}}"/>
                            </VerticalStackLayout>

                            <!-- Amount + date -->
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" Spacing="4">
                                <Label
                                    Text="{Binding FormattedAmount}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource StatusOverdue}"
                                    HorizontalTextAlignment="End"/>
                                <Label
                                    Text="{Binding ExpenseDate, Converter={StaticResource ShortDateConverter}}"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                    HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>

                            <BoxView
                                Grid.ColumnSpan="3"
                                VerticalOptions="End"
                                HeightRequest="1"
                                Margin="-16,8,-16,-8"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Empty state -->
            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Padding="40,0"
                Spacing="12"
                IsVisible="{Binding IsEmpty}">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="200"
                    Source="empty_invoices_icon.png"/>
                <Label
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    Text="Aucune dépense"/>
                <Label
                    HorizontalTextAlignment="Center"
                    FontSize="14"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                    Text="Vos dépenses apparaîtront ici."/>
            </VerticalStackLayout>

        </Grid>
    </RefreshView>

        <!-- Bouton flottant : nouvelle dépense -->
        <Button
            Text="+"
            FontSize="26"
            FontAttributes="Bold"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            Padding="0"
            BackgroundColor="{StaticResource Primary}"
            TextColor="White"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,20,20"
            Command="{Binding NewExpenseCommand}"/>

    </Grid>

</ContentPage>
