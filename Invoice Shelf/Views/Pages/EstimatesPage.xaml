<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tabview="clr-namespace:MPowerKit.TabView;assembly=MPowerKit.TabView"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Pages"
             xmlns:controls="clr-namespace:InvoiceShelf.Controls"
             x:Class="InvoiceShelf.Views.Pages.EstimatesPage"
             xmlns:loc="clr-namespace:InvoiceShelf.Localization"
             x:DataType="viewmodels:EstimatesViewModel"
             Title="{loc:Translate Shell_Estimates}">

    <Grid Style="{StaticResource ResponsiveContainer}">
        <tabview:TabView
            BackgroundColor="Transparent"
            SelectedHeaderBackgroundColor="Transparent">

            <tabview:TabView.HeaderItemsLayout>
                <Grid
                    ColumnDefinitions="*,*,*"
                    BackgroundColor="Transparent"
                    WidthRequest="{Binding Width, Source={RelativeSource Mode=FindAncestor, AncestorType={x:Type ScrollView}}}"/>
            </tabview:TabView.HeaderItemsLayout>

            <tabview:TabView.HeaderTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid RowDefinitions="*,Auto">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding .}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                            VerticalOptions="Center"
                            Margin="0,12"/>
                        <Border
                            Grid.Row="1"
                            HeightRequest="2"
                            HorizontalOptions="Fill"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                    </Grid>
                </DataTemplate>
            </tabview:TabView.HeaderTemplate>

            <tabview:TabView.SelectedHeaderTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid RowDefinitions="*,Auto" BackgroundColor="Transparent">
                        <Label
                            Grid.Row="0"
                            HorizontalOptions="Center"
                            Text="{Binding .}"
                            TextColor="{StaticResource Primary}"
                            FontAttributes="Bold"
                            VerticalOptions="Center"
                            Margin="0,12"/>
                        <Border
                            Grid.Row="1"
                            HeightRequest="2.5"
                            HorizontalOptions="Fill"
                            BackgroundColor="{StaticResource Primary}"/>
                    </Grid>
                </DataTemplate>
            </tabview:TabView.SelectedHeaderTemplate>

            <!-- Brouillons -->
            <tabview:TabViewItem Header="{loc:Translate Estimates_TabDrafts}" Column="0">
                <Grid x:DataType="viewmodels:EstimatesViewModel">
                    <controls:EstimateListView
                        ItemsSource="{Binding Drafts}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenEstimateCommand}"
                        EmptyMessage="{loc:Translate Estimates_EmptyDraftsTitle}"
                        EmptySubMessage="{loc:Translate Estimates_EmptyDraftsSub}"/>
                </Grid>
            </tabview:TabViewItem>

            <!-- Envoyés -->
            <tabview:TabViewItem Header="{loc:Translate Estimates_TabSent}" Column="1">
                <Grid x:DataType="viewmodels:EstimatesViewModel">
                    <controls:EstimateListView
                        ItemsSource="{Binding Sents}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenEstimateCommand}"
                        EmptyMessage="{loc:Translate Estimates_EmptySentTitle}"
                        EmptySubMessage="{loc:Translate Estimates_EmptySentSub}"/>
                </Grid>
            </tabview:TabViewItem>

            <!-- Tous -->
            <tabview:TabViewItem Header="{loc:Translate Estimates_TabAll}" Column="2">
                <Grid x:DataType="viewmodels:EstimatesViewModel">
                    <controls:EstimateListView
                        ItemsSource="{Binding Estimates}"
                        IsRefreshing="{Binding IsRefreshing}"
                        RefreshCommand="{Binding RefreshCommand}"
                        SelectionCommand="{Binding OpenEstimateCommand}"
                        EmptyMessage="{loc:Translate Estimates_EmptyAllTitle}"
                        EmptySubMessage="{loc:Translate Estimates_EmptyAllSub}"/>
                </Grid>
            </tabview:TabViewItem>

        </tabview:TabView>

        <!-- Bouton flottant : nouveau devis -->
        <Button
            Text="+"
            FontSize="26"
            FontAttributes="Bold"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            Padding="0"
            BackgroundColor="{StaticResource Primary}"
            TextColor="White"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,20,20"
            Command="{Binding NewEstimateCommand}"/>
    </Grid>
</ContentPage>
