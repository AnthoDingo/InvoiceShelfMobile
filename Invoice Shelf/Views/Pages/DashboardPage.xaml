                                        <Label Text="{Binding FormattedTotal}" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding InvoiceDate, Converter={StaticResource ShortDateConverter}}"
                                               FontSize="12" HorizontalTextAlignment="End"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                                    </VerticalStackLayout>
                                    <BoxView Grid.ColumnSpan="2" VerticalOptions="End" HeightRequest="1"
