<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Pages"
             x:Class="InvoiceShelf.Views.Pages.LockPage"
             x:DataType="viewmodels:LockViewModel"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             xmlns:loc="clr-namespace:InvoiceShelf.Localization"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Primary}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:IsNotNullConverter x:Key="IsNotNullConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" Padding="32" Style="{StaticResource ResponsiveContainer}">

        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">

            <Label
                Text="🔒"
                FontSize="56"
                HorizontalTextAlignment="Center"/>

            <Label
                Text="{loc:Translate Lock_Title}"
                TextColor="White"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"/>

            <Label
                Text="{loc:Translate Lock_Subtitle}"
                TextColor="White"
                Opacity="0.8"
                FontSize="14"
                HorizontalTextAlignment="Center"/>

            <ActivityIndicator
                IsRunning="{Binding IsAuthenticating}"
                IsVisible="{Binding IsAuthenticating}"
                Color="White"
                Margin="0,10,0,0"/>

            <Label
                Text="{Binding ErrorMessage}"
                TextColor="White"
                FontSize="13"
                HorizontalTextAlignment="Center"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"/>

            <Button
                Text="{loc:Translate Lock_Retry}"
                Command="{Binding AttemptUnlockCommand}"
                BackgroundColor="White"
                TextColor="{StaticResource Primary}"
                FontAttributes="Bold"
                CornerRadius="10"
                Padding="24,12"
                Margin="0,10,0,0"/>

        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Text="{loc:Translate Lock_Logout}"
            Command="{Binding LogoutCommand}"
            BackgroundColor="Transparent"
            TextColor="White"
            FontAttributes="Bold"
            Margin="0,0,0,16"/>

    </Grid>
</ContentPage>
