<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Invoices"
             xmlns:models="clr-namespace:InvoiceShelf.Models.Admin"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             x:Class="InvoiceShelf.Views.Invoices.InvoiceDetailPage"
             x:DataType="viewmodels:InvoiceDetailViewModel"
             Title="{Binding Invoice.InvoiceNumber}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            <helpers:IsNotNullConverter     x:Key="IsNotNullConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Style="{StaticResource ResponsiveContainer}">

        <!-- Chargement -->
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="14"
            IsVisible="{Binding IsLoading}">
            <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" WidthRequest="36" HeightRequest="36"/>
            <Label Text="Chargement…" TextColor="{StaticResource Gray400}" HorizontalOptions="Center" FontSize="14"/>
        </VerticalStackLayout>

        <!-- Contenu -->
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,48">

                <!-- En-tête coloré -->
                <Border
                    Margin="16,16,16,0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{StaticResource Primary}"
                    Padding="20,22">
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                Text="{Binding Invoice.InvoiceNumber}"
                                TextColor="White"
                                FontSize="20"
                                FontAttributes="Bold"/>
                            <Border
                                Grid.Column="1"
                                StrokeShape="RoundRectangle 6"
                                StrokeThickness="1.5"
                                Stroke="White"
                                BackgroundColor="Transparent"
                                Padding="10,4">
                                <Label
                                    Text="{Binding Invoice.FormattedStatus}"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="12"/>
                            </Border>
                        </Grid>

                        <Label
                            Text="{Binding Invoice.FormattedTotal}"
                            TextColor="White"
                            FontSize="38"
                            FontAttributes="Bold"/>

                        <Grid ColumnDefinitions="*,*" Margin="0,6,0,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <Label Text="Date de facture" TextColor="White" Opacity="0.65" FontSize="11"/>
                                <Label Text="{Binding Invoice.FormattedInvoiceDate}" TextColor="White" FontSize="13"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                <Label Text="Date d'échéance" TextColor="White" Opacity="0.65" FontSize="11"/>
                                <Label Text="{Binding Invoice.FormattedDueDate}" TextColor="White" FontSize="13"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Solde dû (si > 0) -->
                        <Border
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="White"
                            Opacity="0.15"
                            Padding="12,8"
                            IsVisible="{Binding Invoice.DueAmount, Converter={StaticResource IsNotNullConverter}}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Solde dû" TextColor="White" FontSize="13"/>
                                <Label Grid.Column="1" Text="{Binding Invoice.FormattedDueAmount}" TextColor="White" FontAttributes="Bold" FontSize="13"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Client -->
                <Border
                    Margin="16,12,16,0"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="CLIENT" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               CharacterSpacing="1"/>
                        <Label Text="{Binding Invoice.Customer.Name}" FontSize="16" FontAttributes="Bold"/>
                        <Label Text="{Binding Invoice.Customer.Email}" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               IsVisible="{Binding Invoice.Customer.Email, Converter={StaticResource IsNotNullConverter}}"/>
                        <Label Text="{Binding Invoice.Customer.Phone}" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               IsVisible="{Binding Invoice.Customer.Phone, Converter={StaticResource IsNotNullConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Articles -->
                <Border
                    Margin="16,12,16,0"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    IsVisible="{Binding HasItems}">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="ARTICLES" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               CharacterSpacing="1"
                               Margin="0,0,0,10"/>
                        <CollectionView ItemsSource="{Binding Invoice.Items}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Item">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"/>
                                            <Label Text="{Binding QuantityUnit}" FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding FormattedTotal}"
                                               FontSize="14" FontAttributes="Bold"
                                               HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Récapitulatif financier -->
                <Border
                    Margin="16,12,16,0"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="RÉCAPITULATIF" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               CharacterSpacing="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Sous-total" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Grid.Column="1" Text="{Binding Invoice.FormattedSubTotal}" FontSize="14" HorizontalTextAlignment="End"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Taxes" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Grid.Column="1" Text="{Binding Invoice.FormattedTax}" FontSize="14" HorizontalTextAlignment="End"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Remise" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Grid.Column="1" Text="{Binding Invoice.FormattedDiscount}" FontSize="14"
                                   TextColor="{StaticResource StatusCompleted}" HorizontalTextAlignment="End"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Total" FontSize="17" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="{Binding Invoice.FormattedTotal}"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" HorizontalTextAlignment="End"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Solde dû" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                            <Label Grid.Column="1" Text="{Binding Invoice.FormattedDueAmount}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource StatusOverdue}" HorizontalTextAlignment="End"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Enregistrer un paiement (visible si solde dû > 0) -->
                <Button
                    Margin="16,12,16,0"
                    Text="Enregistrer un paiement"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Command="{Binding RecordPaymentCommand}"
                    IsVisible="{Binding CanRecordPayment}"/>

                <!-- Modifier (visible uniquement sur une facture en brouillon) -->
                <Button
                    Margin="16,12,16,0"
                    Text="Modifier"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource White}}"
                    Command="{Binding EditInvoiceCommand}"
                    IsVisible="{Binding IsDraft}"/>

                <!-- Notes -->
                <Border
                    Margin="16,12,16,0"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    IsVisible="{Binding HasNotes}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="NOTES" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               CharacterSpacing="1"/>
                        <Label Text="{Binding Invoice.Notes}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
