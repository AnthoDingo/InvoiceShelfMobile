<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InvoiceShelf.ViewModels.Expenses"
             xmlns:helpers="clr-namespace:InvoiceShelf.Helpers"
             x:Class="InvoiceShelf.Views.Expenses.CreateExpensePage"
             xmlns:loc="clr-namespace:InvoiceShelf.Localization"
             x:DataType="viewmodels:CreateExpenseViewModel"
             Title="{loc:Translate Expense_NewTitle}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            <helpers:IsNotNullConverter     x:Key="IsNotNullConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <!-- Chargement -->
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="14"
            IsVisible="{Binding IsLoading}">
            <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}" WidthRequest="36" HeightRequest="36"/>
            <Label Text="{loc:Translate Common_Loading}" TextColor="{StaticResource Gray400}" HorizontalOptions="Center" FontSize="14"/>
        </VerticalStackLayout>

        <!-- Formulaire -->
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="16" Padding="16,16,16,32">

                <!-- Erreur -->
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource StatusOverdue}"
                    FontSize="13"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"/>

                <!-- Catégorie -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate Expense_Category}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <Picker
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="{loc:Translate Expense_SelectCategory}"/>
                </VerticalStackLayout>

                <!-- Montant -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate Common_Amount}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <Entry
                        Text="{Binding Amount}"
                        Placeholder="0.00"
                        Keyboard="Numeric"/>
                </VerticalStackLayout>

                <!-- Date de la dépense -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate Expense_ExpenseDate}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <DatePicker Date="{Binding ExpenseDate}"/>
                </VerticalStackLayout>

                <!-- Client (optionnel) -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate Common_Customer}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <Picker
                        ItemsSource="{Binding Customers}"
                        SelectedItem="{Binding SelectedCustomer}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="{loc:Translate Common_SelectOptional}"/>
                </VerticalStackLayout>

                <!-- Mode de paiement (optionnel) -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate RecordPayment_PaymentMethod}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <Picker
                        ItemsSource="{Binding PaymentMethods}"
                        SelectedItem="{Binding SelectedPaymentMethod}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="{loc:Translate Common_SelectOptional}"/>
                </VerticalStackLayout>

                <!-- Notes -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate Common_Notes}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"/>
                    <Editor Text="{Binding Notes}" Placeholder="{loc:Translate Common_Optional}" HeightRequest="90" AutoSize="TextChanges"/>
                </VerticalStackLayout>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button
                        Grid.Column="0"
                        Text="{loc:Translate Common_Cancel}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource White}}"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button
                        Grid.Column="1"
                        Text="{loc:Translate Common_Save}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"/>
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}"
                                    Color="{StaticResource Primary}" HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
