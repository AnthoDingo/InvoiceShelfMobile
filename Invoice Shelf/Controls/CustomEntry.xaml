<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InvoiceShelf.Controls.CustomEntry">
    <VerticalStackLayout>
        <Border 
            Stroke="{Binding BorderStrokeColor, Source={x:Reference Root}}" 
            StrokeThickness="2"
            StrokeShape="RoundRectangle 6"
            Margin="0,20,0,0"
            Padding="0">

            <Entry 
                Margin="0"
                FontSize="18"
                Text="{Binding Text, Source={x:Reference Root}, Mode=TwoWay}"
                Placeholder="{Binding Placeholder, Source={x:Reference Root}}" />
        </Border>

        <Label
            Text="Required field is empty"
            FontSize="12"
            TextColor="Red"
            IsVisible="{Binding IsError, Source={x:Reference Root}}" />

    </VerticalStackLayout>
</ContentView>
